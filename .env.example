# PostgreSQL connection
DATABASE_URL="postgresql://erp:erp@localhost:5432/iraq_erp?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
SESSION_COOKIE_NAME="iraq_erp_session"

# App
NEXT_PUBLIC_APP_NAME="Iraq ERP"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"

# Iraq tax authority integration (placeholders for upcoming e-invoicing)
IQ_GCT_API_URL=""
IQ_GCT_API_KEY=""

# Optional: CBI exchange rates (Central Bank of Iraq)
CBI_RATES_URL="https://cbi.iq/exchange_rates"
