model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number        String
  kind          InvoiceKind   @default(DOMESTIC_SALE)
  reversesInvoiceId String?
  reverses      Invoice?      @relation("InvoiceReverses", fields: [reversesInvoiceId], references: [id])
  reversals     Invoice[]     @relation("InvoiceReverses")
  deletedAt     DateTime?
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  date          DateTime
  dueDate       DateTime?
  paymentTerms  String?
  shippingTerms String?
  importerAddress String?
  exporterAddress String?
  countryOfOrigin String?
  currency      String        @default("IQD")
  fxRate        Decimal       @default(1) @db.Decimal(20, 8)
  subtotal      Decimal       @default(0) @db.Decimal(20, 4)
  taxTotal      Decimal       @default(0) @db.Decimal(20, 4)
  discountTotal Decimal       @default(0) @db.Decimal(20, 4)
  total         Decimal       @default(0) @db.Decimal(20, 4)
  amountPaid    Decimal       @default(0) @db.Decimal(20, 4)
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  postedJournalId String?
  eInvoiceUuid    String?
  eInvoiceStatus  String?
  /// Iraqi tax stamp (طوابع مالية) — required on invoices over a governorate-set threshold.
  taxStampAmount  Decimal       @default(0) @db.Decimal(20, 4)
  taxStampApplied Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lines         InvoiceLine[]
  payments      PaymentApplication[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, date])
}

enum InvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REVERSED
}

enum InvoiceKind {
  DOMESTIC_SALE
  EXPORT
  IMPORT
  CREDIT_NOTE
  DEBIT_NOTE
}

