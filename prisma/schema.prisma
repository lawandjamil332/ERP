model Contact {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deletedAt     DateTime?
  kind          ContactKind @default(CUSTOMER)
  customerType  CustomerType @default(INDIVIDUAL)
  /// Display code: CUS-26056-85317 / SUP-26056-12345
  reference     String?
  nameAr        String
  nameEn        String?
  company       String?
  taxNumber     String?
  commercialReg String?
  phone         String?
  altPhone      String?
  email         String?
  addressAr     String?
  addressEn     String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  governorate   String?
  currency      String      @default("IQD")
  creditLimit   Decimal     @default(0) @db.Decimal(20, 4)
  openingBalance Decimal    @default(0) @db.Decimal(20, 4)
