// Iraq ERP — Multi-tenant Prisma schema
// All monetary values use Decimal(20, 4) to safely hold IQD (no decimal) and USD (2 dp) and FX rates.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ─────────────────────────────────────────────────────────────────────
/// Tenancy & access control
/// ─────────────────────────────────────────────────────────────────────

model Tenant {
  id              String   @id @default(cuid())
  /// Trade name (Arabic)
  nameAr          String
  /// Trade name (Kurdish, optional)
  nameKu          String?
  /// Trade name (English)
  nameEn          String
  /// Iraqi tax number (الرقم الضريبي)
  taxNumber       String?  @unique
  /// Commercial registration number (رقم السجل التجاري)
  commercialReg   String?  @unique
  /// Governorate (محافظة) — e.g. Baghdad, Erbil, Basra
  governorate     String?
  /// Tax region — federal Iraq or Kurdistan Region (KRG has distinct rules:
  /// PIT practically 5%, CIT filing deadline June 30, different SS practice)
  region          TaxRegion @default(FEDERAL)
  /// Sector — affects payroll SS rate (oil & gas = 25% employer)
  sector          BusinessSector @default(GENERAL)
  /// Default currency for ledger (almost always IQD)
  baseCurrency    String   @default("IQD")
  /// Fiscal year start month (Iraq usually calendar year)
  fiscalYearStart Int      @default(1)
  /// Default locale: ar | ku | en
  defaultLocale   String   @default("ar")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  branches        Branch[]
  accounts        Account[]
  journals        Journal[]
  taxRates        TaxRate[]
  contacts        Contact[]
  products        Product[]
  warehouses      Warehouse[]
  invoices        Invoice[]
  purchaseOrders  PurchaseOrder[]
  bills           Bill[]
  payments        Payment[]
  employees       Employee[]
  payrollRuns    PayrollRun[]
  posTerminals    PosTerminal[]
  exchangeRates   ExchangeRate[]
  auditLogs       AuditLog[]
  costCenters     CostCenter[]
  projects        Project[]
  fixedAssets     FixedAsset[]
}

/// Cost centres (IUAS levels 5-9 are reserved for cost accounting)
model CostCenter {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  nameAr    String
  nameEn    String
  parentId  String?
  parent    CostCenter? @relation("CostTree", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostTree")
  isActive  Boolean @default(true)

  @@unique([tenantId, code])
}

/// Projects (especially for construction sector — very common in Iraq)
model Project {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  nameAr       String
  nameEn       String
  clientId     String?
  startDate    DateTime?
  endDate      DateTime?
  contractValue Decimal @default(0) @db.Decimal(20, 4)
  currency     String   @default("IQD")
  status       String   @default("ACTIVE")
  notes        String?

  @@unique([tenantId, code])
}

/// Fixed assets register — IUAS requires asset tracking and depreciation
model FixedAsset {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetCode       String
  nameAr          String
  nameEn          String
  category        String
  acquisitionDate DateTime
  acquisitionCost Decimal  @db.Decimal(20, 4)
  usefulLife      Int
  salvageValue    Decimal  @default(0) @db.Decimal(20, 4)
  method          String   @default("STRAIGHT_LINE")
  decliningRate   Decimal? @db.Decimal(8, 4)
  accumulatedDepreciation Decimal @default(0) @db.Decimal(20, 4)
  netBookValue    Decimal  @default(0) @db.Decimal(20, 4)
  location        String?
  status          String   @default("ACTIVE")
  disposedAt      DateTime?

  @@unique([tenantId, assetCode])
}

enum TaxRegion {
  FEDERAL
  KURDISTAN
}

enum BusinessSector {
  GENERAL
  OIL_GAS
  TELECOM
  HOSPITALITY
  CONSTRUCTION
  RETAIL
  MANUFACTURING
  AGRICULTURE
  HEALTHCARE
  EDUCATION
  TRANSPORT
}

model Branch {
  id           String @id @default(cuid())
  tenantId     String
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nameAr       String
  nameEn       String
  code         String
  governorate  String?
  address      String?
  phone        String?

  warehouses   Warehouse[]
  posTerminals PosTerminal[]

  @@unique([tenantId, code])
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email         String
  /// Argon2id hash
  passwordHash  String
  fullName      String
  phone         String?
  role          UserRole @default(STAFF)
  locale        String   @default("ar")
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs     AuditLog[]

  @@unique([tenantId, email])
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  SALES
  PURCHASES
  INVENTORY
  HR
  CASHIER
  STAFF
  AUDITOR_READONLY
}

/// ─────────────────────────────────────────────────────────────────────
/// Accounting — Chart of Accounts, Journals, Ledger
/// Based on the Iraqi Unified Accounting System (النظام المحاسبي الموحد)
/// ─────────────────────────────────────────────────────────────────────

model Account {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  nameAr      String
  nameEn      String
  type        AccountType
  parentId    String?
  parent      Account?     @relation("AccountTree", fields: [parentId], references: [id])
  children    Account[]    @relation("AccountTree")
  isPostable  Boolean      @default(true)
  isActive    Boolean      @default(true)

  lines       JournalLine[]

  @@unique([tenantId, code])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model Journal {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference   String
  date        DateTime
  dateHijri   String?
  memo        String?
  source      JournalSource @default(MANUAL)
  isPosted    Boolean       @default(false)
  postedAt    DateTime?
  postedById  String?

  createdAt   DateTime      @default(now())
  lines       JournalLine[]

  @@unique([tenantId, reference])
  @@index([tenantId, date])
}

enum JournalSource {
  MANUAL
  SALES_INVOICE
  PURCHASE_BILL
  PAYMENT
  PAYROLL
  POS
  INVENTORY_ADJUSTMENT
  YEAR_END_CLOSING
  OPENING_BALANCE
}

model JournalLine {
  id         String   @id @default(cuid())
  journalId  String
  journal    Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id])
  debit      Decimal  @default(0) @db.Decimal(20, 4)
  credit     Decimal  @default(0) @db.Decimal(20, 4)
  currency   String   @default("IQD")
  fxRate     Decimal  @default(1) @db.Decimal(20, 8)
  memo       String?
  contactId  String?
  costCenter String?

  @@index([accountId])
}

model TaxRate {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  nameAr    String
  nameEn    String
  rate      Decimal    @db.Decimal(8, 4)
  kind      TaxKind    @default(SALES)
  accountId String?
  isActive  Boolean    @default(true)

  @@unique([tenantId, code])
}

enum TaxKind {
  SALES
  WITHHOLDING
  CUSTOMS
  VAT
  STAMP
}

model ExchangeRate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency  String
  rate      Decimal  @db.Decimal(20, 8)
  date      DateTime
  source    String   @default("CBI")

  @@unique([tenantId, currency, date])
  @@index([tenantId, currency, date])
}

model Contact {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind          ContactKind @default(CUSTOMER)
  nameAr        String
  nameEn        String?
  taxNumber     String?
  commercialReg String?
  phone         String?
  email         String?
  addressAr     String?
  addressEn     String?
  governorate   String?
  currency      String      @default("IQD")
  creditLimit   Decimal     @default(0) @db.Decimal(20, 4)
  notes         String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]
  bills          Bill[]
  payments       Payment[]

  @@index([tenantId, kind])
}

enum ContactKind {
  CUSTOMER
  SUPPLIER
  BOTH
}

model Warehouse {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch? @relation(fields: [branchId], references: [id])
  code      String
  nameAr    String
  nameEn    String
  address   String?
  isActive  Boolean @default(true)

  stockItems Stock[]

  @@unique([tenantId, code])
}

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku          String
  barcode      String?
  nameAr       String
  nameEn       String
  descriptionAr String?
  descriptionEn String?
  hsCode       String?
  countryOfOrigin String?
  trademark    String?
  unitOfMeasure String  @default("PCS")
  category     String?
  salePrice    Decimal  @default(0) @db.Decimal(20, 4)
  cost         Decimal  @default(0) @db.Decimal(20, 4)
  taxRateId    String?
  isService    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  stock        Stock[]
  invoiceLines InvoiceLine[]
  billLines    BillLine[]

  @@unique([tenantId, sku])
}

model Stock {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Decimal  @default(0) @db.Decimal(20, 4)
  reorderAt   Decimal  @default(0) @db.Decimal(20, 4)

  @@unique([productId, warehouseId])
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number        String
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  date          DateTime
  dueDate       DateTime?
  /// Iraq Nov-2025 invoice fields
  paymentTerms  String?
  shippingTerms String?
  importerAddress String?
  exporterAddress String?
  countryOfOrigin String?
  currency      String        @default("IQD")
  fxRate        Decimal       @default(1) @db.Decimal(20, 8)
  subtotal      Decimal       @default(0) @db.Decimal(20, 4)
  taxTotal      Decimal       @default(0) @db.Decimal(20, 4)
  discountTotal Decimal       @default(0) @db.Decimal(20, 4)
  total         Decimal       @default(0) @db.Decimal(20, 4)
  amountPaid    Decimal       @default(0) @db.Decimal(20, 4)
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  postedJournalId String?
  eInvoiceUuid    String?
  eInvoiceStatus  String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         InvoiceLine[]
  payments      PaymentApplication[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, date])
}

enum InvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  hsCode      String?
  countryOfOrigin String?
  trademark   String?
  quantity    Decimal @db.Decimal(20, 4)
  unitOfMeasure String @default("PCS")
  unitPrice   Decimal @db.Decimal(20, 4)
  discount    Decimal @default(0) @db.Decimal(20, 4)
  taxRate     Decimal @default(0) @db.Decimal(8, 4)
  taxAmount   Decimal @default(0) @db.Decimal(20, 4)
  lineTotal   Decimal @db.Decimal(20, 4)
}

model PurchaseOrder {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number    String
  supplierId String
  supplier  Contact  @relation(fields: [supplierId], references: [id])
  date      DateTime
  status    POStatus @default(DRAFT)
  currency  String   @default("IQD")
  total     Decimal  @default(0) @db.Decimal(20, 4)
  notes     String?

  bills     Bill[]

  @@unique([tenantId, number])
}

enum POStatus { DRAFT  APPROVED  RECEIVED  CLOSED  CANCELLED }

model Bill {
  id            String     @id @default(cuid())
  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number        String
  supplierId    String
  supplier      Contact    @relation(fields: [supplierId], references: [id])
  poId          String?
  po            PurchaseOrder? @relation(fields: [poId], references: [id])
  date          DateTime
  dueDate       DateTime?
  currency      String     @default("IQD")
  fxRate        Decimal    @default(1) @db.Decimal(20, 8)
  subtotal      Decimal    @default(0) @db.Decimal(20, 4)
  taxTotal      Decimal    @default(0) @db.Decimal(20, 4)
  withholding   Decimal    @default(0) @db.Decimal(20, 4)
  total         Decimal    @default(0) @db.Decimal(20, 4)
  amountPaid    Decimal    @default(0) @db.Decimal(20, 4)
  status        BillStatus @default(DRAFT)
  postedJournalId String?

  lines         BillLine[]
  payments      PaymentApplication[]

  @@unique([tenantId, number])
}

enum BillStatus { DRAFT  POSTED  PARTIALLY_PAID  PAID  OVERDUE  CANCELLED }

model BillLine {
  id          String  @id @default(cuid())
  billId      String
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Decimal @db.Decimal(20, 4)
  unitOfMeasure String @default("PCS")
  unitPrice   Decimal @db.Decimal(20, 4)
  taxRate     Decimal @default(0) @db.Decimal(8, 4)
  taxAmount   Decimal @default(0) @db.Decimal(20, 4)
  lineTotal   Decimal @db.Decimal(20, 4)
}

model Payment {
  id           String              @id @default(cuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number       String
  date         DateTime
  contactId    String
  contact      Contact             @relation(fields: [contactId], references: [id])
  direction    PaymentDirection
  method       PaymentMethod       @default(CASH)
  reference    String?
  currency     String              @default("IQD")
  fxRate       Decimal             @default(1) @db.Decimal(20, 8)
  amount       Decimal             @db.Decimal(20, 4)
  notes        String?
  postedJournalId String?

  applications PaymentApplication[]

  @@unique([tenantId, number])
}

enum PaymentDirection { IN  OUT }
enum PaymentMethod { CASH  BANK_TRANSFER  CHEQUE  CARD  ZAIN_CASH  ASIA_HAWALA  FIB  OTHER }

model PaymentApplication {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  billId    String?
  bill      Bill?    @relation(fields: [billId], references: [id])
  amount    Decimal  @db.Decimal(20, 4)
}

model Employee {
  id                 String          @id @default(cuid())
  tenantId           String
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  empNo              String
  nationalId         String?
  ssNumber           String?
  fullNameAr         String
  fullNameEn         String?
  gender             Gender?
  dateOfBirth        DateTime?
  nationality        String          @default("IQ")
  governorate        String?
  phone              String?
  email              String?
  hireDate           DateTime
  terminationDate    DateTime?
  jobTitle           String?
  department         String?
  baseSalary         Decimal         @db.Decimal(20, 4)
  dependents         Int             @default(0)
  ssEnrolled         Boolean         @default(true)
  isActive           Boolean         @default(true)

  payrollLines       PayrollLine[]

  @@unique([tenantId, empNo])
}

enum Gender { MALE  FEMALE }

model PayrollRun {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period      String
  runDate     DateTime
  status      PayrollStatus   @default(DRAFT)
  notes       String?
  postedJournalId String?

  lines       PayrollLine[]

  @@unique([tenantId, period])
}

enum PayrollStatus { DRAFT  CALCULATED  POSTED  PAID }

model PayrollLine {
  id            String     @id @default(cuid())
  runId         String
  run           PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee   @relation(fields: [employeeId], references: [id])
  baseSalary    Decimal    @db.Decimal(20, 4)
  allowances    Decimal    @default(0) @db.Decimal(20, 4)
  overtime      Decimal    @default(0) @db.Decimal(20, 4)
  bonuses       Decimal    @default(0) @db.Decimal(20, 4)
  gross         Decimal    @db.Decimal(20, 4)
  ssEmployee    Decimal    @db.Decimal(20, 4)
  ssEmployer    Decimal    @db.Decimal(20, 4)
  incomeTax     Decimal    @db.Decimal(20, 4)
  otherDeductions Decimal  @default(0) @db.Decimal(20, 4)
  net           Decimal    @db.Decimal(20, 4)
  notes         String?
}

model PosTerminal {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  code      String
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)

  sessions  PosSession[]

  @@unique([tenantId, code])
}

model PosSession {
  id           String      @id @default(cuid())
  terminalId   String
  terminal     PosTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingFloat Decimal     @default(0) @db.Decimal(20, 4)
  closingCash  Decimal?    @db.Decimal(20, 4)
  notes        String?
  orders       PosOrder[]
}

model PosOrder {
  id         String   @id @default(cuid())
  sessionId  String
  session    PosSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  number     String
  date       DateTime @default(now())
  subtotal   Decimal  @db.Decimal(20, 4)
  taxTotal   Decimal  @default(0) @db.Decimal(20, 4)
  discount   Decimal  @default(0) @db.Decimal(20, 4)
  total      Decimal  @db.Decimal(20, 4)
  paid       Decimal  @default(0) @db.Decimal(20, 4)
  method     PaymentMethod @default(CASH)
  postedJournalId String?

  lines      PosOrderLine[]
}

model PosOrderLine {
  id         String  @id @default(cuid())
  orderId    String
  order      PosOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSku String
  productName String
  quantity   Decimal @db.Decimal(20, 4)
  unitPrice  Decimal @db.Decimal(20, 4)
  taxRate    Decimal @default(0) @db.Decimal(8, 4)
  total      Decimal @db.Decimal(20, 4)
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
