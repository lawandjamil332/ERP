// Iraq ERP — Multi-tenant Prisma schema
// All monetary values use Decimal(20, 4) to safely hold IQD (no decimal) and USD (2 dp) and FX rates.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String   @id @default(cuid())
  nameAr          String
  nameKu          String?
  nameEn          String
  taxNumber       String?  @unique
  commercialReg   String?  @unique
  governorate     String?
  region          TaxRegion @default(FEDERAL)
  sector          BusinessSector @default(GENERAL)
  baseCurrency    String   @default("IQD")
  fiscalYearStart Int      @default(1)
  defaultLocale   String   @default("ar")
  ramadanMode     Boolean  @default(false)
  useArabicNumerals Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  branches        Branch[]
  accounts        Account[]
  journals        Journal[]
  taxRates        TaxRate[]
  contacts        Contact[]
  products        Product[]
  warehouses      Warehouse[]
  invoices        Invoice[]
  purchaseOrders  PurchaseOrder[]
  bills           Bill[]
  payments        Payment[]
  employees       Employee[]
  payrollRuns     PayrollRun[]
  posTerminals    PosTerminal[]
  exchangeRates   ExchangeRate[]
  auditLogs       AuditLog[]
  costCenters     CostCenter[]
  projects        Project[]
  fixedAssets     FixedAsset[]
  cheques         Cheque[]
  stockMovements  StockMovement[]
  depreciationRuns DepreciationRun[]
  approvalRules   ApprovalRule[]
  notifications   Notification[]
  totpSecrets     TotpSecret[]
  portalTokens    CustomerPortalToken[]
  hotelFolios     HotelFolio[]
  bom             Bom[]
  workOrders      WorkOrder[]
  bankAccounts    BankAccount[]
  bankStatements  BankStatement[]
  recurringInvoiceTemplates RecurringInvoiceTemplate[]
  leaveTypes      LeaveType[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  uomConversions  UomConversion[]
  stockLots       StockLot[]
  salaryAdvances  SalaryAdvance[]
  passwordResetTokens PasswordResetToken[]
  einvoiceSubmissions EInvoiceSubmission[]
  consolidatedGroups  ConsolidatedGroup[]
  lettersOfCredit     LetterOfCredit[]
  holidays            PublicHoliday[]
  bankGuarantees      BankGuarantee[]
  cbiAuctions         CbiAuction[]
  amlReports          AmlReport[]
  beneficialOwners    BeneficialOwner[]
  pscContracts        PscContract[]
  quotations          Quotation[]
  installmentPlans    InstallmentPlan[]
  documentTemplates   DocumentTemplate[]
  priceLists          PriceList[]
  quoteRequests       QuoteRequest[]
  purchaseReturns     PurchaseReturn[]
  stockCounts         StockCount[]
  brands              Brand[]
  productCategories   ProductCategory[]
  printableTemplates  PrintableTemplate[]
  stockOrders         StockOrder[]
  expenseCategories   ExpenseCategory[]
  incomeCategories    IncomeCategory[]
  roles               Role[]
  uiSettings          Json?
}

/// Recurring invoices — subscriptions, monthly rent, retainers.
model RecurringInvoiceTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  contactId   String
  cadence     RecurringCadence
  cadenceDay  Int?
  startDate   DateTime
  endDate     DateTime?
  lastIssuedAt DateTime?
  nextIssueAt  DateTime
  autoPost     Boolean  @default(false)
  currency     String   @default("IQD")
  fxRate       Decimal  @default(1) @db.Decimal(20, 8)
  paymentTerms String?
  notes        String?
  isActive     Boolean  @default(true)
  lines        RecurringInvoiceLine[]
  createdAt    DateTime @default(now())
}

enum RecurringCadence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model RecurringInvoiceLine {
  id          String   @id @default(cuid())
  templateId  String
  template    RecurringInvoiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(20, 4)
  unitOfMeasure String @default("PCS")
  unitPrice   Decimal  @db.Decimal(20, 4)
  taxRate     Decimal  @default(0) @db.Decimal(8, 4)
}

model LeaveType {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  nameAr      String
  nameEn      String
  annualEntitlement Int @default(0)
  carryForward Boolean @default(false)
  paid         Boolean @default(true)
  isActive     Boolean @default(true)
  requests     LeaveRequest[]
  balances     LeaveBalance[]

  @@unique([tenantId, code])
}

model LeaveRequest {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  decidedBy   String?
  decidedAt   DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([tenantId, employeeId, status])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveBalance {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  year        Int
  entitled    Int    @default(0)
  used        Int    @default(0)
  carriedIn   Int    @default(0)

  @@unique([tenantId, employeeId, leaveTypeId, year])
}

model UomConversion {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  fromUom     String
  toUom       String
  factor      Decimal  @db.Decimal(20, 8)

  @@unique([tenantId, productId, fromUom, toUom])
}

model StockLot {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  warehouseId String
  lotNumber   String
  receivedQty Decimal  @db.Decimal(20, 4)
  remainingQty Decimal @db.Decimal(20, 4)
  unitCost    Decimal  @default(0) @db.Decimal(20, 4)
  manufactureDate DateTime?
  expiryDate  DateTime?
  /// Kimadia (Iraqi state pharma importer) tracking.
  kimadiaLicense  String?
  kimadiaBatchNumber String?
  receivedAt  DateTime @default(now())

  @@index([tenantId, productId, expiryDate])
  @@unique([tenantId, productId, warehouseId, lotNumber])
}

model SalaryAdvance {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  date        DateTime
  amount      Decimal  @db.Decimal(20, 4)
  recovery    String   @default("FULL")
  instalments Int?
  recovered   Decimal  @default(0) @db.Decimal(20, 4)
  status      String   @default("OUTSTANDING")
  notes       String?
  postedJournalId String?
  createdAt   DateTime @default(now())

  @@index([tenantId, employeeId, status])
}

model Cheque {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number       String
  deletedAt    DateTime?
  direction    ChequeDirection
  bank         String
  branch       String?
  drawer       String
  beneficiary  String
  amount       Decimal  @db.Decimal(20, 4)
  currency     String   @default("IQD")
  issueDate    DateTime
  dueDate      DateTime
  status       ChequeStatus @default(REGISTERED)
  contactId    String?
  invoiceId    String?
  billId       String?
  notes        String?
  clearedAt    DateTime?

  @@unique([tenantId, number, direction])
  @@index([tenantId, status])
}

enum ChequeDirection {
  IN
  OUT
}

enum ChequeStatus {
  REGISTERED
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
  REPLACED
}

model StockMovement {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind          StockMovementKind
  date          DateTime
  reference     String
  fromWarehouseId String?
  toWarehouseId   String?
  productId     String
  quantity      Decimal  @db.Decimal(20, 4)
  unitCost      Decimal  @default(0) @db.Decimal(20, 4)
  reason        String?
  postedJournalId String?

  @@index([tenantId, productId])
}

enum StockMovementKind {
  TRANSFER
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  WRITE_OFF
  OPENING_BALANCE
  CONSIGNMENT_OUT
  CONSIGNMENT_RETURN
  CONSIGNMENT_SOLD
}

model DepreciationRun {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period    String
  runDate   DateTime
  total     Decimal  @db.Decimal(20, 4)
  postedJournalId String?

  @@unique([tenantId, period])
}

model ApprovalRule {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entity      String
  thresholdAmount Decimal @db.Decimal(20, 4)
  currency    String   @default("IQD")
  approverRole String
  isActive    Boolean  @default(true)
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  kind      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, userId, readAt])
}

model TotpSecret {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @unique
  secret    String
  enabledAt DateTime?
  createdAt DateTime @default(now())
}

model CustomerPortalToken {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId  String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model EInvoiceSubmission {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId    String
  uuid         String?
  submittedAt  DateTime @default(now())
  status       String
  responseCode String?
  responseBody String?

  @@index([tenantId, invoiceId])
}

model ConsolidatedGroup {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  parentCode String?
  memberTenantIds String[]
  createdAt  DateTime @default(now())
}

/// Letter of Credit — Iraqi importers use these heavily through CBI's foreign-currency window.
model LetterOfCredit {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lcNumber        String
  issuingBank     String
  advisingBank    String?
  beneficiary     String
  beneficiaryCountry String?
  applicant       String
  currency        String   @default("USD")
  amount          Decimal  @db.Decimal(20, 4)
  drawnAmount     Decimal  @default(0) @db.Decimal(20, 4)
  issueDate       DateTime
  expiryDate      DateTime
  lastShipmentDate DateTime?
  incoterms       String?
  status          LcStatus @default(OPEN)
  relatedBillId   String?
  relatedPoId     String?
  cbiWindowDate   DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  drawings        LcDrawing[]

  @@unique([tenantId, lcNumber])
  @@index([tenantId, status])
}

enum LcStatus {
  OPEN
  PARTIALLY_DRAWN
  FULLY_DRAWN
  EXPIRED
  CANCELLED
}

model LcDrawing {
  id          String   @id @default(cuid())
  lcId        String
  lc          LetterOfCredit @relation(fields: [lcId], references: [id], onDelete: Cascade)
  date        DateTime
  amount      Decimal  @db.Decimal(20, 4)
  documents   String?
  notes       String?
}

model PublicHoliday {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date        DateTime
  nameAr      String
  nameEn      String
  scope       HolidayScope  @default(FEDERAL)
  isMovable   Boolean       @default(false)

  @@index([date])
}

enum HolidayScope {
  FEDERAL
  KURDISTAN
  BOTH
}

/// Bank guarantee (خطاب الضمان) — required for government tenders and PO collateral.
model BankGuarantee {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference     String
  kind          BgKind   @default(PERFORMANCE)
  issuingBank   String
  beneficiary   String
  amount        Decimal  @db.Decimal(20, 4)
  currency      String   @default("IQD")
  issueDate     DateTime
  expiryDate    DateTime
  status        BgStatus @default(ACTIVE)
  relatedProjectId String?
  notes         String?
  createdAt     DateTime @default(now())

  @@unique([tenantId, reference])
  @@index([tenantId, status])
}

enum BgKind {
  BID
  PERFORMANCE
  ADVANCE_PAYMENT
  RETENTION
  CUSTOMS
  OTHER
}

enum BgStatus {
  ACTIVE
  RELEASED
  CALLED
  EXPIRED
}

/// CBI USD foreign-currency auction tracker (Iraqi importers bid weekly through the Central Bank window).
model CbiAuction {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auctionDate     DateTime
  bidAmount       Decimal  @db.Decimal(20, 4)
  allocatedAmount Decimal  @default(0) @db.Decimal(20, 4)
  rate            Decimal  @db.Decimal(20, 8)
  bidBank         String
  purpose         String
  status          CbiAuctionStatus @default(SUBMITTED)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([tenantId, auctionDate])
}

enum CbiAuctionStatus {
  SUBMITTED
  PARTIALLY_FILLED
  FILLED
  REJECTED
}

/// Anti-money-laundering threshold report (Iraqi FIU mandates report for cash transactions over IQD 15M).
model AmlReport {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggerEntity String   // "Payment", "Invoice", "Bill"
  triggerId     String
  contactName   String?
  amount        Decimal  @db.Decimal(20, 4)
  currency      String   @default("IQD")
  reason        String
  reportedAt    DateTime?
  reportReference String?
  createdAt     DateTime @default(now())

  @@index([tenantId, reportedAt])
}

/// Beneficial owner registry — mandatory since 2024 for all Iraqi companies.
model BeneficialOwner {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName        String
  nationalId      String?
  nationality     String   @default("IQ")
  dateOfBirth     DateTime?
  ownershipPct    Decimal  @db.Decimal(8, 4)
  controlMechanism String?
  isPep           Boolean  @default(false)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

/// Production-sharing contract (PSC) — oil & gas sector contracts.
model PscContract {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractNumber  String
  fieldName       String
  signedDate      DateTime
  expiryDate      DateTime?
  /// Cost-recovery cap as a fraction of revenue (e.g. 0.50 = 50%).
  costRecoveryCap Decimal  @default(0.50) @db.Decimal(8, 4)
  /// Profit-oil split for the contractor (the rest goes to the government).
  contractorProfitShare Decimal @default(0.20) @db.Decimal(8, 4)
  /// Royalty rate paid first.
  royaltyRate     Decimal  @default(0.10) @db.Decimal(8, 4)
  notes           String?
  createdAt       DateTime @default(now())
  periods         PscPeriod[]

  @@unique([tenantId, contractNumber])
}

model PscPeriod {
  id              String   @id @default(cuid())
  contractId      String
  contract        PscContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  period          String   // YYYY-MM or YYYY-Qx
  grossRevenue    Decimal  @db.Decimal(20, 4)
  recoverableCosts Decimal @db.Decimal(20, 4)
  royaltyPaid     Decimal  @db.Decimal(20, 4)
  costRecovered   Decimal  @db.Decimal(20, 4)
  profitOil       Decimal  @db.Decimal(20, 4)
  contractorShare Decimal  @db.Decimal(20, 4)
  governmentShare Decimal  @db.Decimal(20, 4)
  createdAt       DateTime @default(now())

  @@unique([contractId, period])
}

model HotelFolio {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number       String
  guestName    String
  guestIdType  String?
  guestIdNumber String?
  roomNumber   String
  checkIn      DateTime
  checkOut     DateTime?
  status       FolioStatus  @default(OPEN)
  notes        String?
  charges      HotelFolioCharge[]

  @@unique([tenantId, number])
}

enum FolioStatus {
  OPEN
  CHECKED_OUT
  CANCELLED
}

model HotelFolioCharge {
  id        String  @id @default(cuid())
  folioId   String
  folio     HotelFolio @relation(fields: [folioId], references: [id], onDelete: Cascade)
  date      DateTime  @default(now())
  description String
  amount    Decimal @db.Decimal(20, 4)
  taxRate   Decimal @default(0.10) @db.Decimal(8, 4)
  taxAmount Decimal @db.Decimal(20, 4)
}

model Bom {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId String
  version   String   @default("1")
  isActive  Boolean  @default(true)
  components BomComponent[]
  workOrders WorkOrder[]

  @@unique([tenantId, productId, version])
}

model BomComponent {
  id        String  @id @default(cuid())
  bomId     String
  bom       Bom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentProductId String
  quantity  Decimal @db.Decimal(20, 4)
  unitOfMeasure String @default("PCS")
}

model WorkOrder {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number     String
  bomId      String
  bom        Bom      @relation(fields: [bomId], references: [id])
  quantity   Decimal  @db.Decimal(20, 4)
  status     WoStatus @default(DRAFT)
  startDate  DateTime?
  endDate    DateTime?
  notes      String?

  @@unique([tenantId, number])
}

enum WoStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model BankAccount {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  bankName  String
  iban      String?
  accountNumber String
  currency  String   @default("IQD")
  isActive  Boolean  @default(true)
  statements BankStatement[]

  @@unique([tenantId, accountNumber])
}

model BankStatement {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccountId String
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  date        DateTime
  reference   String?
  description String?
  debit       Decimal  @default(0) @db.Decimal(20, 4)
  credit      Decimal  @default(0) @db.Decimal(20, 4)
  balance     Decimal? @db.Decimal(20, 4)
  matchedJournalLineId String?
  reconciledAt DateTime?

  @@index([tenantId, bankAccountId, date])
}

model ProjectMilestone {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  percentage Decimal  @db.Decimal(8, 4)
  amount     Decimal  @db.Decimal(20, 4)
  retention  Decimal  @default(0) @db.Decimal(20, 4)
  invoicedAt DateTime?
  invoiceId  String?
  notes      String?
}

model CostCenter {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  nameAr    String
  nameEn    String
  parentId  String?
  parent    CostCenter? @relation("CostTree", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostTree")
  isActive  Boolean @default(true)

  @@unique([tenantId, code])
}

model Project {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  nameAr       String
  nameEn       String
  clientId     String?
  startDate    DateTime?
  endDate      DateTime?
  contractValue Decimal @default(0) @db.Decimal(20, 4)
  currency     String   @default("IQD")
  status       String   @default("ACTIVE")
  notes        String?
  milestones   ProjectMilestone[]

  @@unique([tenantId, code])
}

model FixedAsset {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetCode       String
  nameAr          String
  nameEn          String
  category        String
  acquisitionDate DateTime
  acquisitionCost Decimal  @db.Decimal(20, 4)
  usefulLife      Int
  salvageValue    Decimal  @default(0) @db.Decimal(20, 4)
  method          String   @default("STRAIGHT_LINE")
  decliningRate   Decimal? @db.Decimal(8, 4)
  accumulatedDepreciation Decimal @default(0) @db.Decimal(20, 4)
  netBookValue    Decimal  @default(0) @db.Decimal(20, 4)
  location        String?
  status          String   @default("ACTIVE")
  disposedAt      DateTime?

  @@unique([tenantId, assetCode])
}

enum TaxRegion {
  FEDERAL
  KURDISTAN
}

enum BusinessSector {
  GENERAL
  OIL_GAS
  TELECOM
  HOSPITALITY
  CONSTRUCTION
  RETAIL
  MANUFACTURING
  AGRICULTURE
  HEALTHCARE
  EDUCATION
  TRANSPORT
}

model Branch {
  id            String @id @default(cuid())
  tenantId      String
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nameAr        String
  nameEn        String
  code          String
  email         String?
  phone         String?
  altPhone      String?
  taxNumber     String?
  commercialReg String?
