// Iraq ERP — Multi-tenant Prisma schema
// All monetary values use Decimal(20, 4) to safely hold IQD (no decimal) and USD (2 dp) and FX rates.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String   @id @default(cuid())
  nameAr          String
  nameKu          String?
  nameEn          String
  taxNumber       String?  @unique
  commercialReg   String?  @unique
  governorate     String?
  region          TaxRegion @default(FEDERAL)
  sector          BusinessSector @default(GENERAL)
  baseCurrency    String   @default("IQD")
  fiscalYearStart Int      @default(1)
  defaultLocale   String   @default("ar")
  ramadanMode     Boolean  @default(false)
  useArabicNumerals Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  branches        Branch[]
  accounts        Account[]
  journals        Journal[]
  taxRates        TaxRate[]
  contacts        Contact[]
  products        Product[]
  warehouses      Warehouse[]
  invoices        Invoice[]
  purchaseOrders  PurchaseOrder[]
  bills           Bill[]
  payments        Payment[]
  employees       Employee[]
  payrollRuns     PayrollRun[]
  posTerminals    PosTerminal[]
  exchangeRates   ExchangeRate[]
  auditLogs       AuditLog[]
  costCenters     CostCenter[]
  projects        Project[]
  fixedAssets     FixedAsset[]
  cheques         Cheque[]
  stockMovements  StockMovement[]
  depreciationRuns DepreciationRun[]
  approvalRules   ApprovalRule[]
  notifications   Notification[]
  totpSecrets     TotpSecret[]
  portalTokens    CustomerPortalToken[]
  hotelFolios     HotelFolio[]
  bom             Bom[]
  workOrders      WorkOrder[]
  bankAccounts    BankAccount[]
  bankStatements  BankStatement[]
  recurringInvoiceTemplates RecurringInvoiceTemplate[]
  leaveTypes      LeaveType[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  uomConversions  UomConversion[]
  stockLots       StockLot[]
  salaryAdvances  SalaryAdvance[]
  passwordResetTokens PasswordResetToken[]
  einvoiceSubmissions EInvoiceSubmission[]
  consolidatedGroups  ConsolidatedGroup[]
  lettersOfCredit     LetterOfCredit[]
  holidays            PublicHoliday[]
  bankGuarantees      BankGuarantee[]
  cbiAuctions         CbiAuction[]
  amlReports          AmlReport[]
  beneficialOwners    BeneficialOwner[]
  pscContracts        PscContract[]
  quotations          Quotation[]
  installmentPlans    InstallmentPlan[]
  documentTemplates   DocumentTemplate[]
  priceLists          PriceList[]
  quoteRequests       QuoteRequest[]
  purchaseReturns     PurchaseReturn[]
  stockCounts         StockCount[]
  brands              Brand[]
  productCategories   ProductCategory[]
  printableTemplates  PrintableTemplate[]
  uiSettings          Json?
}

